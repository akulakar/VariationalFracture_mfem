 RowBox[{
  RowBox[{"meshrefFunc", "=", 
   RowBox[{"Function", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"vertices", ",", "Area"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"Block", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", "y", ",", "tol"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}], "=", 
         RowBox[{"Mean", "[", "vertices", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"tol", "=", "0.001"}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"Sqrt", "[", 
            RowBox[{
             SuperscriptBox["x", "2"], "+", 
             SuperscriptBox["y", "2"]}], "]"}], ">", 
           RowBox[{"radius", "-", "tol"}]}], " ", ",", 
          RowBox[{"Area", "<", "elArea"}], ",", 
